# ── Database ──────────────────────────────────────────────────────────────────
DB_URL=postgres://ap2user:ap2pass@postgres:5432/ap2db?sslmode=disable

# ── RabbitMQ ──────────────────────────────────────────────────────────────────
RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672/

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── Order Service – Cache ─────────────────────────────────────────────────────
CACHE_TTL_SECONDS=300          # 5 minutes TTL for order cache

# ── Order Service – Rate Limiter (Bonus) ──────────────────────────────────────
RATE_LIMIT_REQUESTS=10         # max requests per window
RATE_LIMIT_WINDOW_SECONDS=60   # window size in seconds

# ── Notification Service – Provider ───────────────────────────────────────────
PROVIDER_MODE=SIMULATED        # SIMULATED | REAL

# SMTP settings (only used when PROVIDER_MODE=REAL)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=your-email@gmail.com

# ── Notification Service – Worker Pool ────────────────────────────────────────
NUM_WORKERS=3                  # number of parallel "barista" goroutines

# ── Notification Service – Retry ──────────────────────────────────────────────
MAX_RETRIES=3                  # max retry attempts per notification
RETRY_BASE_SECONDS=2           # base backoff: 2s, 4s, 8s ...

# ── Notification Service – Idempotency ────────────────────────────────────────
IDEMPOTENCY_TTL_HOURS=48       # how long to keep processed event keys in Redis
